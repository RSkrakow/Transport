# Supabase – skopiuj z Settings > API w dashboardzie Supabase
NEXT_PUBLIC_SUPABASE_URL=https://TWOJ_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=twoj_anon_key_tutaj

# Secret używany tylko po stronie serwera (Server Actions)
SUPABASE_SERVICE_ROLE_KEY=twoj_service_role_key_tutaj

# Opcjonalne: domyślna cena paliwa (EUR/l) jeśli nie ma w bazie
DEFAULT_FUEL_PRICE_EUR=1.25
